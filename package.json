{
  "name": "themoviesstop",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "start:dev": "nodemon ./bin/www",
    "test": "NODE_ENV=test jest --runInBand --forceExit",
    "heroku-postbuild": "cd frontend && npm install --include=dev && npm run build"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "body-parser": "^1.20.4",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.0",
    "debug": "~4.4.3",
    "dotenv": "^17.4.1",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.3",
    "memcached": "^2.2.2",
    "mongodb": "^6.8.0",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "serve-favicon": "~2.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
